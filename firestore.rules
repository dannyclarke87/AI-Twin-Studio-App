rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-.@]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'danny@easypeasybusiness.com') ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'admin'
        )
      );
    }

    function isValidUser(data) {
      let isCreate = request.method == 'create';
      let hasKeys = isCreate ? data.keys().hasAll(['email', 'status', 'createdAt']) && data.keys().size() <= 4 : true;
      let validEmail = !('email' in data) || (data.email is string && data.email.size() <= 300);
      let validStatus = !('status' in data) || (data.status in ['unpaid', 'paid', 'admin', 'legacy', 'starter', 'pro', 'elite']);
      return hasKeys && validEmail && validStatus;
    }

    match /users/{userId} {
      allow get: if isValidId(userId) && (isOwner(userId) || isAdmin() || (isSignedIn() && 'email' in request.auth.token && userId == request.auth.token.email.lower()));
      // Admin can list all. Users can only list if they filter by their own email securely
      allow list: if isAdmin() || (isSignedIn() && 'email' in request.auth.token && resource.data.email == request.auth.token.email);
      
      allow create: if isValidId(userId)
                    && (
                      (isOwner(userId)
                        && isValidUser(incoming())
                        && 'email' in request.auth.token
                        && incoming().email == request.auth.token.email
                        && (
                          (request.auth.token.email == 'danny@easypeasybusiness.com' && incoming().status == 'admin') ||
                          (incoming().status == 'unpaid') ||
                          ((incoming().status == 'legacy' || incoming().status == 'paid' || incoming().status == 'admin')
                            && exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower()))
                            && get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.status == incoming().status)
                        ))
                      ||
                      (isAdmin() && isValidUser(incoming()))
                    );
                     
      allow update: if isValidId(userId)
                    && isValidUser(incoming())
                    && (
                      (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                      (isOwner(userId) && !isAdmin() && existing().status == 'unpaid' && incoming().status == 'paid' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
                    );

      allow delete: if isValidId(userId) && (isAdmin() || (isSignedIn() && 'email' in request.auth.token && userId == request.auth.token.email.lower()));
    }
  }
}
